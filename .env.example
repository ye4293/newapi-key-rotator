# ---- new-api connection (required) ----
# new-api base URL, no trailing slash
NEWAPI_BASE_URL=https://api.example.com
# Admin system access token: new-api 个人设置页 → 生成系统访问令牌
NEWAPI_ACCESS_TOKEN=replace-with-admin-access-token
# The user id that owns the token above (must be an admin/root user)
NEWAPI_USER_ID=1
# Target single-key channel id to keep alive
CHANNEL_ID=123

# ---- web console (strongly recommended to set a password) ----
WEB_LISTEN=:8080
WEB_USERNAME=admin
WEB_PASSWORD=change-me

# ---- behaviour (optional) ----
# How often to check the channel status
POLL_INTERVAL=60s
# Per-request timeout against new-api
HTTP_TIMEOUT=15s
# Where pool.json is stored (matches the docker volume mount)
DATA_DIR=/data
# Set true only if new-api uses a self-signed TLS certificate
INSECURE_SKIP_VERIFY=false
